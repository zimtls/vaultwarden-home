# {{ ansible_managed }}
# Reverse proxy Vaultwarden — TLS terminé ici, backend loopback

server {
    listen 443 ssl;
    http2 on;
    server_name {{ vw_domain }};

    ssl_certificate     {{ vw_tls_cert }};
    ssl_certificate_key {{ vw_tls_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;

    # Icônes de sites + pièces jointes : autoriser des uploads raisonnables
    client_max_body_size 128M;

    # HSTS (VPN/LAN only mais bonne hygiène)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://{{ vw_bind }};
        proxy_http_version 1.1;

        # WebSocket (notifications temps réel, intégré depuis VW 1.29+)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 90s;
    }
}

# Redirection HTTP -> HTTPS (optionnelle, décommenter si port 80 ouvert)
server {
     listen 80;
     server_name {{ vw_domain }};
     return 301 https://$host$request_uri;
}
